<h1>Hermes Sessions</h1>
<table>
  <tr>
    <th>Session ID</th>
    <th>Model</th>
    <th>Status</th>
    <th>Messages</th>
  </tr>
  <%= for session <- @sessions do %>
    <tr>
      <td><%= session.id %></td>
      <td><%= session.model %></td>
      <td><%= session.status %></td>
      <td><%= session.message_count %></td>
    </tr>
  <% end %>
</table>
