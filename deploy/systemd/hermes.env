# WARNING: Do not commit real secrets to this file.
# Replace placeholders before deploy and consider using a secrets manager
# or systemd's LoadCredential= for production deployments.
PHX_SERVER=true
PORT=4000
DATABASE_PATH=/var/lib/hermes/hermes.db
SECRET_KEY_BASE=<generate with mix phx.gen.secret>
ANTHROPIC_API_KEY=<set on deploy>
